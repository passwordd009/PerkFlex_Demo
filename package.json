{
  "name": "perkflex",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev\" \"tsx watch server/index.ts\" --names \"next,api\" --prefix-colors \"cyan,magenta\"",
    "dev:next": "next dev",
    "dev:api": "tsx watch server/index.ts",
    "build": "next build && vite build",
    "build:next": "next build",
    "build:api": "vite build",
    "start": "concurrently \"next start\" \"node dist/server/index.js\" --names \"next,api\"",
